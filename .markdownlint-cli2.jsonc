{
  // markdownlint-cli2 設定。整形は Prettier に任せ、ここは構造/内容を lint する。
  "config": {
    "default": true,
    // 行長は Prettier(proseWrap: preserve)と日本語テキストに合わないため無効化
    "MD013": false,
    // 太字ラベルを見出し代わりに使う文書を許容（厳しくするなら true に戻す）
    "MD036": false,
    // リンクは参照スタイル（[text][label] ＋末尾に [label]: URL）に統一。
    // inline [text](url) は禁止。裸 URL は autolink <url> でよい。
    "MD054": {
      "autolink": true,
      "inline": false,
      "full": true,
      "collapsed": true,
      "shortcut": true,
      "url_inline": false
    }
  },
  "globs": ["**/*.md"],
  // Respect .gitignore so generated/working files (e.g. tmp/) are not linted.
  // Keeps markdownlint aligned with Prettier, which already honors .gitignore.
  "gitignore": true,
  "ignores": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    ".claude",
    "CHANGELOG.md",
    // changesets の生成 README と contributor が書く changeset(.md) は参照スタイル強制の対象外
    ".changeset"
  ]
}
