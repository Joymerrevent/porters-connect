{
  "packageManager": "pnpm",
  "testRunner": "vitest",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "reporters": ["progress", "clear-text", "html"],
  "mutate": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "!src/**/index.ts",
    "!src/**/types.ts",
    "!src/types/**",
    "!src/fields/**"
  ],
  "thresholds": { "high": 100, "low": 95, "break": 95 },
  "ignorePatterns": ["dist", "coverage", ".stryker-tmp", "reports"]
}
