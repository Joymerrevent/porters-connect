{
  "name": "@joymerrevent/porters-connect",
  "version": "0.1.1",
  "description": "Unofficial type-safe TypeScript wrapper for the PORTERS Connect API (formerly HRBC).",
  "keywords": [
    "porters",
    "hrbc",
    "porters-connect",
    "connect-api",
    "recruiting",
    "ats",
    "typescript",
    "api-client",
    "unofficial"
  ],
  "homepage": "https://github.com/Joymerrevent/porters-connect#readme",
  "bugs": {
    "url": "https://github.com/Joymerrevent/porters-connect/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Joymerrevent/porters-connect.git"
  },
  "license": "MIT",
  "author": "Joymerrevent (https://joymerrevent.com/)",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.29.3",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "lint:ts": "eslint .",
    "lint:ts:fix": "eslint . --fix",
    "format:ts": "prettier --write \"**/*.{ts,tsx,cts,mts,js,jsx,cjs,mjs,json}\"",
    "format:ts:check": "prettier --check \"**/*.{ts,tsx,cts,mts,js,jsx,cjs,mjs,json}\"",
    "lint": "pnpm run \"/^lint:(?!fix$)[^:]+$/\"",
    "lint:fix": "pnpm run \"/^lint:[^:]+:fix$/\"",
    "format": "pnpm run \"/^format:(?!check$)[^:]+$/\"",
    "format:check": "pnpm run \"/^format:[^:]+:check$/\"",
    "lint:md": "markdownlint-cli2",
    "lint:md:fix": "markdownlint-cli2 --fix",
    "format:md": "prettier --write \"**/*.md\"",
    "format:md:check": "prettier --check \"**/*.md\"",
    "typecheck": "tsc --noEmit",
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean --target node20",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "mutation": "stryker run",
    "sandbox": "tsx examples/offline-sandbox.ts",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "lint-staged": "^17.0.7",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.4",
    "simple-git-hooks": "^2.13.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "fast-xml-parser": "^5.9.2"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged",
    "commit-msg": "pnpm exec commitlint --edit \"$1\""
  },
  "lint-staged": {
    "*.{ts,tsx,cts,mts,js,jsx,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ],
    "*.md": [
      "markdownlint-cli2 --fix",
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "js-yaml": ">=4.2.0",
      "markdown-it": ">=14.2.0",
      "esbuild": ">=0.28.1",
      "qs": ">=6.15.2"
    }
  }
}
